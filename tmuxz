#!/usr/bin/env bash
set -euo pipefail

cmd_name=$(basename "$0")

# ---------------------------------------------------------------------------
# Socket detection – adapted from tmux-bridge
# ---------------------------------------------------------------------------

die() {
    echo "$cmd_name: $*" >&2
    exit 1
}

detect_socket() {
    # 1. Explicit environment-variable override
    if [[ -n "${TMUXZ_SOCKET:-}" ]]; then
        if [[ -S "$TMUXZ_SOCKET" ]]; then
            echo "$TMUXZ_SOCKET"; return
        fi
        die "TMUXZ_SOCKET=$TMUXZ_SOCKET is not a valid socket"
    fi

    # 2. Extract from $TMUX (format: "socket_path,pid,session_index")
    if [[ -n "${TMUX:-}" ]]; then
        local socket="${TMUX%%,*}"
        if [[ -S "$socket" ]]; then
            if tmux -S "$socket" list-sessions &>/dev/null; then
                echo "$socket"; return
            fi
        fi
    fi

    # 3. Scan socket directories for a server that owns $TMUX_PANE
    local pane="${TMUX_PANE:-}"
    if [[ -n "$pane" ]]; then
        local uid; uid=$(id -u)
        local sock_dirs=("/tmp/tmux-${uid}" "/private/tmp/tmux-${uid}")
        for sock_dir in "${sock_dirs[@]}"; do
            [[ -d "$sock_dir" ]] || continue
            for sock in "$sock_dir"/*; do
                [[ -S "$sock" ]] || continue
                if tmux -S "$sock" display-message -t "$pane" -p '#{pane_id}' &>/dev/null; then
                    echo "$sock"; return
                fi
            done
        done
        # Try the default server
        if tmux display-message -t "$pane" -p '#{pane_id}' &>/dev/null; then
            echo "__default__"; return
        fi
    fi

    # 4. Last resort: default tmux server
    if tmux list-sessions &>/dev/null; then
        echo "__default__"; return
    fi

    die "cannot find a reachable tmux server"
}

TMUX_SOCKET=""
init_socket() { TMUX_SOCKET=$(detect_socket); }

# Socket-aware tmux wrapper
tmx() {
    if [[ "$TMUX_SOCKET" == "__default__" || -z "$TMUX_SOCKET" ]]; then
        tmux "$@"
    else
        tmux -S "$TMUX_SOCKET" "$@"
    fi
}

# ---------------------------------------------------------------------------
# Read Guard – enforces read-before-act
# ---------------------------------------------------------------------------

read_guard_path() {
    local pane_id="$1"
    # Sanitize: %66 → _66
    echo "/tmp/tmuxz-read-${pane_id//%/_}"
}

mark_read()   { touch "$(read_guard_path "$1")"; }
clear_read()  { rm -f "$(read_guard_path "$1")"; }

require_read() {
    local guard
    guard=$(read_guard_path "$1")
    if [[ ! -f "$guard" ]]; then
        die "must read the pane before interacting. Run: $cmd_name bridge read $1"
    fi
}

# ---------------------------------------------------------------------------
# Target resolution
# ---------------------------------------------------------------------------

resolve_target() {
    local target="$1"
    # tmux pane ID like %0, %12
    if [[ "$target" =~ ^%[0-9]+$ ]]; then
        echo "$target"; return
    fi
    # Looks like a tmux target with colon or dot (session:win.pane)
    if [[ "$target" == *:* ]] || [[ "$target" == *.* ]]; then
        echo "$target"; return
    fi
    # Pure numeric — treat as window index
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        echo "$target"; return
    fi
    # Otherwise resolve as a @name label
    resolve_label "$target"
}

resolve_label() {
    local label="$1"
    local result
    result=$(tmx list-panes -a -F '#{pane_id} #{@name}' 2>/dev/null \
        | awk -v lbl="$label" '$2 == lbl { print $1; exit }')
    if [[ -z "$result" ]]; then
        die "no pane found with label '$label'"
    fi
    echo "$result"
}

validate_target() {
    local target="$1"
    tmx display-message -t "$target" -p '#{pane_id}' >/dev/null 2>&1 \
        || die "invalid target: $target"
}

# ---------------------------------------------------------------------------
# Bridge commands
# ---------------------------------------------------------------------------

bridge_read() {
    if [[ $# -lt 1 ]]; then
        die "'bridge read' requires at least 1 argument: <target> [lines]"
    fi
    local target
    target=$(resolve_target "$1")
    validate_target "$target"
    local lines="${2:-50}"
    tmx capture-pane -t "$target" -p -J -S "-${lines}"
    mark_read "$target"
}

bridge_type() {
    if [[ $# -lt 2 ]]; then
        die "'bridge type' requires at least 2 arguments: <target> <text>"
    fi
    local target
    target=$(resolve_target "$1")
    validate_target "$target"
    require_read "$target"
    tmx send-keys -t "$target" -l -- "$2"
    clear_read "$target"
}

bridge_keys() {
    if [[ $# -lt 2 ]]; then
        die "'bridge keys' requires at least 2 arguments: <target> <key> [key ...]"
    fi
    local target
    target=$(resolve_target "$1")
    validate_target "$target"
    require_read "$target"
    shift
    for key in "$@"; do
        tmx send-keys -t "$target" "$key"
    done
    clear_read "$target"
}

bridge_name() {
    if [[ $# -lt 2 ]]; then
        die "'bridge name' requires at least 2 arguments: <target> <label>"
    fi
    local target
    target=$(resolve_target "$1")
    validate_target "$target"
    tmx set-option -p -t "$target" @name "$2"
}

# ---------------------------------------------------------------------------
# Usage / help
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
Usage: $cmd_name <subcommand> [options] [arguments]

Subcommands:
  new-window     Create a new window (same as tmux new-window)
  split-window   Create a new pane by splitting (same as tmux split-window)
  list-panes     List all panes on the server (same as tmux list-panes -a)
  bridge         Cross-pane communication (read/type/keys/name)

Options for new-window:
  new-window [-abdkPS] [-c start-directory] [-e environment] [-F format]
             [-n window-name] [-t target-window] [shell-command [argument ...]]

Options for split-window:
  split-window [-bdfhIvPZ] [-c start-directory] [-e environment] [-F format]
               [-l size] [-t target-pane] [shell-command [argument ...]]

Options for list-panes:
  list-panes [-F format] [-f filter]

Bridge commands:
  bridge read  <target> [lines]   Read last N lines from pane (default: 50)
  bridge type  <target> <text>    Type literal text without pressing Enter
  bridge keys  <target> <key>...  Send special keys (Enter, Escape, C-c, etc.)
  bridge name  <target> <label>   Label a pane (stored as @name option)

Target resolution:
  Targets can be tmux native (%N, session:window.pane) or a @name label
  set via 'bridge name'. Labels are resolved automatically.

Read guard:
  type and keys require a prior 'bridge read' on the same target.
  This enforces read-before-act to prevent blind commands.

Environment variables:
  TMUXZ_SOCKET   Override socket path (skips auto-detection)

Run '$cmd_name <subcommand> --help' for more information.
EOF
}

subcmd_help() {
    local subcmd="$1"
    case "$subcmd" in
        new-window)
            cat <<'EOF'
new-window [-abdkPS] [-c start-directory] [-e environment] [-F format]
           [-n window-name] [-t target-window] [shell-command [argument ...]]

Create a new window. With -a or -b, the new window is inserted at the next
index after or before the specified target-window, moving windows up if
necessary; otherwise target-window is the new window location.

  -a              Insert after target-window
  -b              Insert before target-window
  -d              Don't make the new window the current window
  -k              Kill existing window if target exists
  -P              Print information about the new window
  -S              Select existing window by name if it exists
  -c directory    Set working directory
  -e VAR=val      Set environment variable (may be repeated)
  -F format       Output format for -P
  -n name         Set window name
  -t target       Specify target window
EOF
            ;;
        split-window)
            cat <<'EOF'
split-window [-bdfhIvPZ] [-c start-directory] [-e environment] [-F format]
             [-l size] [-t target-pane] [shell-command [argument ...]]

Create a new pane by splitting target-pane: -h does a horizontal split and
-v a vertical split; if neither is specified, -v is assumed.

  -b              Create new pane to the left of or above target
  -d              Don't make the new pane the active pane
  -f              Create pane spanning full window height/width
  -h              Horizontal split (left/right)
  -I              Create empty pane, forward stdin to it
  -v              Vertical split (top/bottom, default)
  -P              Print information about the new pane
  -Z              Zoom handling
  -c directory    Set working directory
  -e VAR=val      Set environment variable (may be repeated)
  -F format       Output format for -P
  -l size         Size of the new pane (lines or columns, may end with %)
  -t target       Specify target pane
EOF
            ;;
        list-panes)
            cat <<'EOF'
list-panes [-F format] [-f filter]

List all panes on the server (equivalent to tmux list-panes -a).

  -F format       Specify output format
  -f filter       Only show panes for which filter is true
EOF
            ;;
        bridge)
            cat <<'EOF'
bridge <action> <target> [arguments]

Cross-pane communication with read-before-act guard.

Actions:
  read  <target> [lines]   Read last N lines from pane (default: 50)
  type  <target> <text>    Type literal text without pressing Enter
  keys  <target> <key>...  Send special keys (Enter, Escape, C-c, etc.)
  name  <target> <label>   Label a pane (stored as @name option)

Target resolution:
  Targets can be tmux native (%N, session:window.pane) or a @name label
  set via 'bridge name'. Labels are resolved automatically.

Read guard:
  'type' and 'keys' require a prior 'bridge read' on the same target.
  This enforces read-before-act to prevent blind commands.
  The guard is cleared after each type/keys action, so you must
  read again before the next interaction.

Examples:
  tmuxz bridge name %0 agent1
  tmuxz bridge read  agent1
  tmuxz bridge type  agent1 "hello"
  tmuxz bridge read  agent1
  tmuxz bridge keys  agent1 Enter
EOF
            ;;
        *)
            echo "Unknown subcommand: $subcmd"
            usage
            return 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

subcmd="$1"
shift

case "$subcmd" in
    -h|--help|help)
        usage
        exit 0
        ;;
    new-window)
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
            subcmd_help new-window
            exit 0
        fi
        init_socket
        tmx new-window "$@"
        ;;
    split-window)
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
            subcmd_help split-window
            exit 0
        fi
        init_socket
        tmx split-window "$@"
        ;;
    list-panes)
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
            subcmd_help list-panes
            exit 0
        fi
        init_socket
        tmx list-panes -a "$@"
        ;;
    bridge)
        if [[ $# -lt 1 || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
            subcmd_help bridge
            exit 0
        fi
        local_action="$1"
        shift
        init_socket
        case "$local_action" in
            read)  bridge_read  "$@" ;;
            type)  bridge_type  "$@" ;;
            keys)  bridge_keys  "$@" ;;
            name)  bridge_name  "$@" ;;
            *)
                echo "Unknown bridge action: $local_action" >&2
                subcmd_help bridge >&2
                exit 1
                ;;
        esac
        ;;
    *)
        echo "Unknown subcommand: $subcmd" >&2
        usage >&2
        exit 1
        ;;
esac
